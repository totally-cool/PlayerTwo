{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PlayerTwo",
  "version": "0.1.1",
  "identifier": "com.tgris.playertwo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PlayerTwo",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/totally-cool/PlayerTwo/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYzNkU0NkIxMEI2RUIxQTMKUldTanNXNExzVVp1WStvT2dRQXg0ditUZzRSRTFpa3RPR3AxZEhQNExtbVVxWGk4Y2FiWWdINk8K"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
